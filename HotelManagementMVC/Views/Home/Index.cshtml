@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .hero-section {
        height: 500px;
        background: url('/Content/images/hotel1.jpg') no-repeat center;
        background-size: cover;
        position: relative;
        color: white;
    }

    .hero-overlay {
        background: rgba(0,0,0,0.6);
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        text-align: center;
    }

    .booking-bar {
        background: white;
        padding: 20px;
        border-radius: 10px;
        margin-top: 30px;
        box-shadow: 0px 5px 15px gray;
    }

    .section-title {
        color: darkgoldenrod;
        margin-bottom: 20px;
    }

    .room-card img {
        height: 200px;
        object-fit: cover;
    }
</style>

<!-- HERO -->
<div class="hero-section">
    <div class="hero-overlay animate__animated animate__fadeIn">
        <h1 class="display-3">Welcome to RK Hotel</h1>
        <p class="lead">Experience Luxury, Comfort & Elegance</p>

        @*<div>
                <a href="/Account/Login" class="btn btn-warning btn-lg m-2">Login</a>
                <a href="/Account/Register" class="btn btn-outline-light btn-lg m-2">Register</a>
            </div>*@
    </div>
</div>

<!-- BOOKING BAR -->
<div class="container booking-bar">
    <div class="row text-center">

        <div class="col-md-3">
            <label>Check-In</label>
            <input type="date" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Check-Out</label>
            <input type="date" class="form-control" />
        </div>

        <div class="col-md-2">
            <label>Guests</label>
            <select class="form-control">
                <option>1</option>
                <option>2</option>
            </select>
        </div>

        <div class="col-md-2">
            <label>Room</label>
            <select class="form-control">
                <option>Deluxe</option>
                <option>Suite</option>
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            @if (Session["Username"] == null)
            {
                <a href="/Account/Login" class="btn btn-dark w-100">
                    Search
                </a>
            }
            else
            {
                <a href="/Hotel/Booking" class="btn btn-dark w-100">
                    Search
                </a>
            }
        </div>

    </div>
</div>

<!-- ROOMS -->
<div class="container mt-5">
    <h2 class="text-center section-title">Our Rooms</h2>

    <div class="row">

        <div class="col-md-4">
            <div class="card room-card shadow">
                <img src="/Content/images/room.jpg" />
                <div class="card-body">
                    <h5>Deluxe Room</h5>
                    <p>Spacious room with luxury interiors.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card room-card shadow">
                <img src="/Content/images/lobby.jpg" />
                <div class="card-body">
                    <h5>Suite Room</h5>
                    <p>Premium suite with city view.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card room-card shadow">
                <img src="/Content/images/hotel1.jpg" />
                <div class="card-body">
                    <h5>Luxury Villa</h5>
                    <p>Private villa with top-class facilities.</p>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- AMENITIES -->
<div class="container mt-5">
    <h2 class="text-center section-title">Amenities</h2>

    <div class="row text-center">

        <div class="col-md-3">🏊 Swimming Pool</div>
        <div class="col-md-3">🍽 Fine Dining</div>
        <div class="col-md-3">💆 Spa & Wellness</div>
        <div class="col-md-3">📶 Free WiFi</div>

    </div>
</div>

<!-- GALLERY -->
<div class="container mt-5">
    <h2 class="text-center section-title">Gallery</h2>

    <div class="row">
        <div class="col-md-4"><img src="/Content/images/hotel1.jpg" class="img-fluid rounded" /></div>
        <div class="col-md-4"><img src="/Content/images/room.jpg" class="img-fluid rounded" /></div>
        <div class="col-md-4"><img src="/Content/images/lobby.jpg" class="img-fluid rounded" /></div>
    </div>
</div>



<!-- CTA -->
<div class="text-center mt-5 mb-5">
    <h3>Book your dream stay today!</h3>
    <a href="/Hotel/Register" class="btn btn-warning btn-lg">Book Now</a>
</div>


