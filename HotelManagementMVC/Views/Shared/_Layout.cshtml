<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>

    <!-- Bootstrap -->
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <!-- Animate CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f5f0;
        }

        header {
            background: black;
            color: gold;
            padding: 0px;
        }


        #mainNavbar {
            background: rgba(0,0,0,0.3);
            backdrop-filter: blur(5px);
            transition: all 0.4s ease;
            background: transparent;
            padding: 15px 30px;
        }

            /* When scrolled */
            #mainNavbar.scrolled {
                background: black;
                box-shadow: 0px 3px 10px rgba(0,0,0,0.5);
                padding: 10px 30px;
            }

            /* Navbar links */
            #mainNavbar .nav-link {
                color: white !important;
                font-weight: 500;
            }

            #mainNavbar.scrolled .nav-link {
                color: white !important;
            }

            /* Brand color */
            #mainNavbar .navbar-brand {
                color: gold !important;
                font-weight: bold;
            }
        .navbar-toggler {
            border-color: white;
        }

        .navbar-toggler-icon {
            filter: invert(1);
        }

        nav a {
            color: white;
            margin-right: 15px;
            text-decoration: none;
        }

            nav a:hover {
                color: gold;
            }

        footer {
            background: black;
            color: white;
        }

        .hero {
            height: 400px;
            background: url('/Content/images/hotel1.jpg') no-repeat center;
            background-size: cover;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <header>
        <nav id="mainNavbar" class="navbar navbar-expand-lg fixed-top">

            <!-- LEFT: BRAND -->
            <a class="navbar-brand" href="/">
                <img src="~/Content/images/hotelLogo1.png" style="height:50px;" />
            </a>

            <!-- TOGGLE (mobile) -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- RIGHT SIDE -->
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">

                <ul class="navbar-nav align-items-center">

                    <li class="nav-item">
                        @Html.ActionLink("Home", "Index", "Home", null, new { @class = "nav-link" })
                    </li>

                    @if (Session["Username"] == null)
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Login", "Login", "Account", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Register", "Register", "Account", null, new { @class = "nav-link" })
                        </li>
                    }
                    else
                    {
                        <!-- MENU LINKS -->
                        <li class="nav-item">
                            @Html.ActionLink("Users", "Dashboard", "User", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Hotel", "Register", "Hotel", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Details", "Details", "Hotel", null, new { @class = "nav-link" })
                        </li>

                        <!-- PROFILE DROPDOWN -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center"
                               href="#"
                               id="profileDropdown"
                               role="button"
                               data-bs-toggle="dropdown">

                                <!-- PROFILE ICON -->
                                <img src="https://cdn-icons-png.flaticon.com/512/847/847969.png"
                                     width="35"
                                     height="35"
                                     style="border-radius:50%; margin-right:5px;" />

                                @Session["Username"]
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li class="dropdown-item text-muted">
                                    👤 @Session["Username"]
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                @if (Session["Role"] != null && Session["Role"].ToString() == "Admin")
                                {
                                    <li>
                                        <a class="dropdown-item" href="/Admin/Dashboard">
                                            Admin Dashboard
                                        </a>
                                    </li>
                                }

                                <li>
                                    <a class="dropdown-item" href="/User/Dashboard">
                                        My Dashboard
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="/Hotel/Details">
                                        My Hotels
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <a class="dropdown-item text-danger" href="/Account/Logout">
                                        Logout
                                    </a>
                                </li>

                            </ul>
                        </li>
                    }

                </ul>
            </div>
        </nav>
    </header>

    <div class="hero animate__animated animate__zoomIn">
        Experience Luxury Stay
    </div>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="text-center p-2 mt-4">
        © Rohith Kumar Project
    </footer>

    <script>
        window.addEventListener("scroll", function () {
            let navbar = document.getElementById("mainNavbar");

            if (window.scrollY > 50) {
                navbar.classList.add("scrolled");
            } else {
                navbar.classList.remove("scrolled");
            }
        });
    </script>

</body>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
</html>