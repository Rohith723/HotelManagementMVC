@model HotelManagementMVC.Models.User

@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .register-bg {
        background: url('/Content/images/room.jpg') no-repeat center;
        background-size: cover;
        padding: 50px 0;
    }

    .register-card {
        width: 80%;
        margin: auto;
        background: rgba(255,255,255,0.95);
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0px 0px 20px gray;
    }

    .form-control {
        height: 45px;
        font-size: 16px;
    }

    .section-title {
        color: darkgoldenrod;
        font-weight: bold;
    }
</style>

<div class="register-bg">

    <div class="register-card animate__animated animate__fadeInUp">

        <h2 class="text-center mb-4">Create Your Luxury Account</h2>

        @using (Html.BeginForm())
        {
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row">

                <!-- LEFT SIDE -->
                <div class="col-md-6">

                    <h4 class="section-title">Basic Details</h4>

                    <div class="form-group mb-3">
                        <label>First Name</label>
                        @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control" })
                    </div>

                    <div class="form-group mb-3">
                        <label>Last Name</label>
                        @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                    </div>

                    <div class="form-group mb-3">
                        <label>Username</label>
                        @Html.TextBoxFor(m => m.Username, new { @class = "form-control" })
                    </div>

                    <div class="mb-3">
                        <label>Gender</label><br />
                        @Html.RadioButtonFor(m => m.Gender, "Male") Male
                        @Html.RadioButtonFor(m => m.Gender, "Female") Female
                        @Html.ValidationMessageFor(m => m.Gender)
                    </div>

                    <div class="form-group mb-3">
                        <label>Age</label>
                        @Html.TextBoxFor(m => m.Age, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Age, "", new { @class = "text-danger" })
                    </div>

                </div>

                <!-- RIGHT SIDE -->
                <div class="col-md-6">

                    <h4 class="section-title">Security & Contact</h4>

                    <div class="form-group mb-3">
                        <label>Password</label>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group mb-3">
                        <label>Confirm Password</label>
                        @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group mb-3">
                        <label>Email</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                    </div>

                    <div class="form-group mb-3">
                        <label>Phone</label>
                        @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
                    </div>

                </div>

            </div>

            <hr />

            <!-- FULL WIDTH -->
            <div class="row">

                <div class="col-md-6">
                    <label>Languages</label><br />
                    <input type="checkbox" name="Languages" value="English" /> English
                    <input type="checkbox" name="Languages" value="Telugu" /> Telugu
                    <input type="checkbox" name="Languages" value="Hindi" /> Hindi
                </div>

                <div class="col-md-6">
                    <label>Country</label>
                    @Html.DropDownListFor(m => m.Country,
                        new SelectList(new[] { "India", "USA", "UK", "Pakistan", "Australia" }),
                        "--Select--",
                        new { @class = "form-control" })
                </div>

            </div>

            <div class="mt-3">
                <label>Address</label>
                @Html.TextAreaFor(m => m.Address, new { @class = "form-control" })
            </div>

            <br />

            <button type="submit" class="btn btn-warning w-100" style="height:50px; font-size:18px;">
                Register
            </button>
        }
    </div>

</div>