@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .login-bg {
        height: 100vh;
        background: url('/Content/images/lobby.jpg') no-repeat center;
        background-size: cover;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        width: 450px;
        padding: 40px;
        border-radius: 15px;
        background: rgba(0,0,0,0.7);
        color: white;
        box-shadow: 0px 0px 20px rgba(0,0,0,0.8);
    }

        .login-card input {
            height: 45px;
            font-size: 18px;
        }

        .login-card button {
            width: 100%;
            height: 50px;
            font-size: 18px;
        }
</style>

<div class="login-bg">

    <div class="login-card animate__animated animate__zoomIn">
        <h2 class="text-center mb-4">Welcome Back</h2>

        <form method="post">

            <div class="form-group mb-3">
                <label>Username</label>
                <input type="text" name="Username" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label>Password</label>
                <input type="password" name="Password" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-warning">Login</button>

            <br /><br />

            <a href="/Account/Register" class="btn btn-outline-light w-100">
                New User? Register
            </a>

            <p class="text-danger mt-2">@ViewBag.Error</p>

        </form>
    </div>

</div>